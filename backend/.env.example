# Application
APP_PORT=3000
APP_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_pg_user
DB_PASSWORD=your_pg_password
DB_NAME=whatsapp_gateway

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# WhatsApp Session Storage
WA_SESSION_PATH=./sessions

# API Security
MASTER_TOKEN=change-this-to-a-secure-random-string

# Webhook
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=5000

# Message Queue (milliseconds)
MESSAGE_DELAY_MIN=1000
MESSAGE_DELAY_MAX=3000

# Development Whitelist for AI CS
# AI_WHITELIST_ENABLED=true  → hanya nomor di AI_WHITELIST_PHONES yang dilayani AI
# AI_WHITELIST_ENABLED=false → semua nomor dilayani (mode produksi)
AI_WHITELIST_ENABLED=true
# Format: 628xxx tanpa + atau spasi, pisahkan koma
# Contoh: AI_WHITELIST_PHONES=6281234567890,6289876543210
AI_WHITELIST_PHONES=

# Media Upload
MEDIA_UPLOAD_DIR=./uploads
# Base URL for serving media files (set to your public server URL, e.g. http://160.22.31.215:3303)
MEDIA_BASE_URL=http://localhost:3303
