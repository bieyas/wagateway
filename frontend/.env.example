# Frontend Environment Variables
# Copy this file to .env and update the values

# Vite Dev Server Port
VITE_PORT=3304

# Backend API Configuration (match your backend APP_PORT)
VITE_API_URL=http://localhost:3303
VITE_API_DOCS_URL=http://localhost:3303/docs

# WebSocket Configuration
VITE_WS_URL=ws://localhost:3303

# App Configuration
VITE_APP_NAME="WA Gateway"
VITE_APP_VERSION=1.0.0
